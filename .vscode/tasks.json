{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Editor",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "default",
                "--target",
                "sokoke_editor"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        }
    ]
}
